import java.io.*;
import java.util.*;
import java.text.*;
import java.math.*;
import java.util.regex.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int line=1;
        while(sc.hasNextLine())
        {
            String input = sc.nextLine();
            System.out.println(line+" "+input);
            line++;
        }
        sc.close();
    }
}
